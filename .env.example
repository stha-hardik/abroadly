# --- LLM providers ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Vector store ---
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=abroadly_knowledge

# --- Postgres ---
POSTGRES_URL=postgresql+asyncpg://abroadly:abroadly@localhost:5432/abroadly

# --- App ---
APP_ENV=dev
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Google OAuth student sign-in ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://abroadly.online/auth/google/callback

# --- Eval layer thresholds ---
EVAL_MIN_RETRIEVAL_SCORE=0.55
EVAL_MIN_GROUNDING_SCORE=0.60
EVAL_SCOPE_STRICT=true

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=15

# --- Outbound email (transactional — welcome message) ---
# Leave SMTP_PASSWORD empty in dev and the email module silently no-ops.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USERNAME=hello@abroadly.online
SMTP_PASSWORD=
EMAIL_FROM_NAME=Abroadly
EMAIL_FROM_ADDRESS=hello@abroadly.online
PUBLIC_SITE_URL=https://abroadly.online
